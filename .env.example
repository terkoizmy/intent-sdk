# Environment Variables — Intent Parser SDK
# Copy to .env and fill in values. NEVER commit .env to git.

# ─────────────────────────────────────────────
# RPC Endpoints
# ─────────────────────────────────────────────

# Ethereum Sepolia (chainId: 11155111)
SEPOLIA_RPC_URL=

# Arbitrum Sepolia (chainId: 421614)
ARB_SEPOLIA_RPC_URL=

# Unichain Sepolia (chainId: 1301) — PRIMARY TESTNET for Phase E
UNICHAIN_SEPOLIA_RPC_URL=

# Base Sepolia (chainId: 84532)
BASE_SEPOLIA_RPC_URL=

# Ethereum Mainnet (chainId: 1) — for Phase D Aave reads (free, no key)
ETH_RPC_URL=

# ─────────────────────────────────────────────
# Wallet
# ─────────────────────────────────────────────

# Solver wallet private key (without 0x prefix)
# Used to sign and broadcast transactions in live mode
SOLVER_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Deployed Contract Addresses
# ─────────────────────────────────────────────

# IntentSettlement proxy address on Unichain Sepolia
# Populated automatically after running the deploy script
SETTLEMENT_CONTRACT_UNICHAIN_SEPOLIA=

# IntentSettlement proxy address on Base Sepolia (optional)
SETTLEMENT_CONTRACT_BASE_SEPOLIA=

# ─────────────────────────────────────────────
# Live Test Helpers
# ─────────────────────────────────────────────

# Optional: A known orderId that was previously opened on-chain
# Used by tests/live/settlement-onchain.test.ts Test 5
TEST_ORDER_ID=
